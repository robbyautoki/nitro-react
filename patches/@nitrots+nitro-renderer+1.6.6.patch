+    private predictOwnAvatarFirstStep(targetX: number, targetY: number): void
+    {
+        const roomId = this._roomEngine.activeRoomId;
+        if(roomId < 0) return;
+
+        const session = this._roomEngine.roomSessionManager && this._roomEngine.roomSessionManager.getSession(roomId);
+        if(!session) return;
+
+        const ownObjectId = session.ownRoomIndex;
+        if(ownObjectId < 0) return;
+
+        const ownObject = this._roomEngine.getRoomObject(roomId, ownObjectId, RoomObjectCategory.UNIT);
+        if(!ownObject || !ownObject.logic) return;
+
+        const logic = ownObject.logic as unknown as MovingObjectLogic;
+        if(!logic.startPredictedMove) return;
+
+        // CSP v8: Use current tile position (prediction only from standstill)
+        const currentLoc = ownObject.getLocation();
+        const currentTileX = Math.round(currentLoc.x);
+        const currentTileY = Math.round(currentLoc.y);
+
+        const dx = targetX - currentTileX;
+        const dy = targetY - currentTileY;
+
+        if(dx === 0 && dy === 0) return;
+
+        let stepX: number;
+        let stepY: number;
+
+        if(Math.abs(dx) <= 1 && Math.abs(dy) <= 1)
+        {
+            stepX = targetX;
+            stepY = targetY;
+        }
+        else
+        {
+            stepX = currentTileX + Math.sign(dx);
+            stepY = currentTileY + Math.sign(dy);
+        }
